{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PicFlip",
  "version": "0.3.0",
  "identifier": "com.picflip.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "PicFlip",
        "width": 1180,
        "height": 800,
        "minWidth": 960,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#f5f5f1",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "GraphicsAndDesign",
    "shortDescription": "Private offline media conversion",
    "longDescription": "Convert images, PDFs, audio, and video without uploading anything.",
    "externalBin": ["binaries/ffmpeg"],
    "resources": ["resources"],
    "copyright": "Copyright © 2026 PicFlip",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
